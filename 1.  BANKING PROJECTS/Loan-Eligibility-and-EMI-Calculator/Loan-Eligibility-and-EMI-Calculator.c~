#include <stdio.h>
#include <math.h>

// Function prototypes
double calculateEMI(double principal, double monthlyRate, int months);
int checkEligibility(double emi, double salary);

int main() {
    double salary, loanAmount, annualRate, monthlyRate, emi;
    int months;

    printf("LOAN ELIGIBILITY AND EMI CALCULATOR\n");

    printf("Enter your monthly salary: ");
    if (scanf("%lf", &salary) != 1) return 1;

    printf("Enter loan amount requested: ");
    if (scanf("%lf", &loanAmount) != 1) return 1;

    printf("Enter annual interest rate (%%): ");
    if (scanf("%lf", &annualRate) != 1) return 1;

    printf("Enter loan tenure (months): ");
    if (scanf("%d", &months) != 1) return 1;

    // Convert annual rate to monthly decimal
    monthlyRate = (annualRate / 12) / 100;

    // Calculate EMI
    emi = calculateEMI(loanAmount, monthlyRate, months);

    printf("\nRESULTS --------------------------\n");
    printf("Calculated Monthly EMI: %.2f\n", emi);

    // Check eligibility (EMI should not exceed 40% of salary)
    if (checkEligibility(emi, salary)) {
        printf("Status: ELIGIBLE for this loan.\n");
        printf("Note: The EMI is within 40%% of your salary.\n\n");
    } else {
        printf("Status: NOT ELIGIBLE for this loan.\n");
        printf("Reason: The EMI exceeds 40%% of your salary.\n\n");
    }

    return 0;
}

/**
 * Calculates EMI using the formula:
 * EMI = [P x R x (1+R)^N] / [(1+R)^N - 1]
 */
double calculateEMI(double principal, double monthlyRate, int months) {
    if (monthlyRate == 0) return principal / months;
    
    double power = pow(1 + monthlyRate, months);
    double emi = (principal * monthlyRate * power) / (power - 1);
    return emi;
}

/**
 * Checks if the customer qualifies for the loan.
 * Criteria: EMI must be less than or equal to 40%% of salary.
 */
int checkEligibility(double emi, double salary) {
    if (emi <= (0.40 * salary)) {
        return 1; // Eligible
    } else {
        return 0; // Not eligible
    }
}


