// This determines whether a customer qualifies for a loan by:
//calculating monthly EMI based on income, loan amount, and interest rate.

#include <stdio.h>
#include <math.h>

// Function prototype
double calculateEMI(double principal, double monthlyRate, int months);
int checkEligibility(double emi, double salary);

int main() {
    double salary;
    double loanAmount;
    double annualRate;
    double monthlyRate;
    double emi;
    int months;

    printf("LOAN ELIGIBILITY & EMI CALCULATOR\n");

    // Input section
    printf("Enter your monthly salary: ");
    scanf("%lf", &salary);

    printf("Enter requested loan amount: ");
    scanf("%lf", &loanAmount);

    printf("Enter annual interest rate (%%): ");
    scanf("%lf", &annualRate);

    printf("Enter loan tenure (months): ");
    scanf("%d", &months);

    // Convert annual rate to monthly decimal
    monthlyRate = (annualRate / 12) / 100;

    // Calculate EMI
    emi = calculateEMI(loanAmount, monthlyRate, months);

    printf("\nCalculated EMI: %.2f\n", emi);

    // Check eligibility
    if (checkEligibility(emi, salary)) {
        printf("? Congratulations! You are eligible for the loan.\n");
    } else {
        printf("? Sorry, you are NOT eligible for the loan.\n");
        printf("Note: Equated Monthly Installment (EMI) should not exceed 40%% of your salary.\n\n\n");
    }

    return 0;
}

// EMI Calculation Function ----------------------------------------------------

/*
EMI FORMULA USED

EMI = [ P æ R æ (1 + R)^N ] / [ (1 + R)^N - 1 ]

Where:
    P = principal = Principal (Loan Amount)
    R = monthlyRate = Monthly Interest Rate (annual rate / 12 / 100)
    N = months = Number of Monthly Installments

This formula calculates the fixed monthly payment required
to fully repay a loan over N months at interest rate R.
*/

// Equated Monthly Installment (EMI)
double calculateEMI(double principal, double monthlyRate, int months) {
    double numerator, denominator, emi;

    numerator = principal * monthlyRate * pow(1 + monthlyRate, months);
    denominator = pow(1 + monthlyRate, months) - 1;

    emi = numerator / denominator;
    return emi;
}

// Eligibility Check Function
int checkEligibility(double emi, double salary) {
    if (emi <= (0.40 * salary))
        return 1; // Eligible
    else
        return 0; // Not eligible
}
